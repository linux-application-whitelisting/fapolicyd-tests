summary: CI test plan that runs only modified tests
prepare:
    how: shell
    script: echo '%_pkgverify_level digest' > /etc/rpm/macros.verify
discover:
    how: fmf
    modified-only: true
    modified-url: https://github.com/linux-application-whitelisting/fapolicyd-tests
    modified-ref: main
execute:
    how: tmt

