summary: test how much does fapolicyd affect a source RPM rebuild
contact: Milos Malik <mmalik@redhat.com>
test: ./runtest.sh
duration: 60m
enabled: true
require:
  - fapolicyd
  - fapolicyd-selinux
  - rpm-build
recommend:
  - dnf-utils
  - yum-utils
tag:
  - NoRHEL4
  - NoRHEL5
  - NoRHEL6
  - NoRHEL7
adjust+:
  - enabled: false
    when: distro == rhel-4, rhel-5, rhel-6, rhel-7
    because: the test is not relevant there
link:
  - verifies: https://issues.redhat.com/browse/RHEL-2611

